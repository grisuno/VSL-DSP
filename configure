#!/bin/bash
# SPDX-License-Identifier: GPL-2.0-or-later
# Configuration script for AudioBox 22 VSL driver

set -e

# Text colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

echo_title() {
    echo -e "${BLUE}=== $1 ===${NC}"
}

echo_info() {
    echo -e "${BLUE}[INFO]${NC} $1"
}

echo_warn() {
    echo -e "${YELLOW}[WARN]${NC} $1"
}

echo_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

echo_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $1"
}

# Check if running as root - we don't require root for configuration checks
if [ "$EUID" -eq 0 ]; then
    echo_warn "Running as root. Some checks might be inaccurate (e.g., $HOME)."
fi

echo_title "AudioBox 22 VSL Driver Configuration"

# Check system architecture
echo_info "Checking system architecture..."
ARCH=$(uname -m)
echo_info "Architecture: $ARCH"

# Check for essential build tools
echo_info "Checking for build tools..."
for tool in gcc make perl; do
    if ! command -v $tool &> /dev/null; then
        echo_error "$tool is required but not installed. Please install it."
        exit 1
    fi
    echo_info "$tool found"
done

# Check for kernel headers
echo_info "Checking for kernel headers..."
KERNEL_VERSION=$(uname -r)
KERNEL_HEADERS="/lib/modules/$KERNEL_VERSION/build"
if [ ! -d "$KERNEL_HEADERS" ]; then
    echo_warn "Kernel headers not found at $KERNEL_HEADERS"
    echo_warn "Please install the kernel headers for your running kernel:"
    echo_warn "  On Debian/Ubuntu: sudo apt install linux-headers-$KERNEL_VERSION"
    echo_warn "  On Fedora: sudo dnf install kernel-devel-$(uname -r)"
    echo_warn "  On Arch: sudo pacman -S linux-headers"
    # We don't exit here because the user might be cross-compiling or have them elsewhere
else
    echo_success "Kernel headers found at $KERNEL_HEADERS"
fi

# Check for the target device (optional but recommended)
echo_info "Checking for AudioBox 22 VSL device..."
if lsusb 2>/dev/null | grep -q "194f:0101"; then
    echo_success "AudioBox 22 VSL device detected (VID:PID = 194f:0101)"
else
    echo_warn "AudioBox 22 VSL device not found. Please connect the device before loading the driver."
    echo_warn "You can still proceed with the installation."
fi

# Summary
echo_title "Configuration Summary"
echo_info "Kernel version: $KERNEL_VERSION"
echo_info "Kernel build directory: $KERNEL_HEADERS"
echo_info "Build tools: gcc, make, perl - OK"
echo_info "Device check: $(lsusb 2>/dev/null | grep "194f:0101" && echo "Found" || echo "Not found (warning only)")"
echo_success "Configuration completed successfully!"
echo_info "You can now run: make && sudo make install"
exit 0