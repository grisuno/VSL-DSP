#!/usr/bin/env bash
# SPDX-License-Identifier: GPL-2.0-or-later
# Verify that the build environment is ready for audiobox_vsl.
# All real build commands live in the top-level Makefile.

set -euo pipefail

KVER="$(uname -r)"
KDIR="/lib/modules/${KVER}/build"

ok()  { echo "  ok    : $*"; }
warn(){ echo "  warn  : $*"; }
fail(){ echo "  fail  : $*"; }

echo "audiobox_vsl environment check"
echo

for tool in gcc make perl; do
    if command -v "$tool" >/dev/null 2>&1; then
        ok "$tool"
    else
        fail "$tool is missing"
        exit 1
    fi
done

if [ -d "$KDIR" ]; then
    ok "kernel headers at $KDIR"
else
    warn "kernel headers not found at $KDIR"
    warn "  install with: sudo ./install.sh"
fi

if command -v depmod >/dev/null 2>&1; then
    ok "depmod"
else
    warn "depmod not found"
fi

if command -v modprobe >/dev/null 2>&1; then
    ok "modprobe"
else
    warn "modprobe not found"
fi

if command -v cmocka >/dev/null 2>&1 || pkg-config --exists cmocka 2>/dev/null; then
    ok "cmocka"
else
    warn "cmocka not found; 'make test' will fail"
    warn "  install with: sudo apt install libcmocka-dev"
fi

if command -v lsusb >/dev/null 2>&1; then
    if lsusb 2>/dev/null | grep -qi "194f:0101\|194f:0102\|194f:0103"; then
        ok "at least one AudioBox VSL device is connected"
    else
        warn "no AudioBox VSL device detected (optional)"
    fi
else
    warn "lsusb not found; cannot probe for devices"
fi

echo
echo "Ready. Next: make   (or: sudo make install)"
